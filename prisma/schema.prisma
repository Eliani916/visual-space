generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  ADMIN
  FOTOGRAFER
  PELANGGAN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ON_PROGRESS
  COMPLETED
  EXPIRED
  CANCELLED
}

enum PaymentMethod {
  TRANSFER
  CASH
}

enum PaymentStatus {
  PENDING
  DP
  LUNAS
  GAGAL
}

enum QueueStatus {
  WAITING
  IN_PROGRESS
  FINISHED
}

model Role {
  id          String    @id @default(uuid())
  name        RoleType  @unique
  description String?
  users       User[]

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("roles")
}

model User {
  id            String    @id @default(uuid())
  roleId        String    @map("role_id")
  name          String
  email         String    @unique
  password      String
  phoneNumber   String?   @map("phone_number")
  
  role          Role      @relation(fields: [roleId], references: [id])
  bookings      Booking[]
  activityLogs  ActivityLog[]

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  @@index([email])
  @@index([roleId])
  @@map("users")
}

model Package {
  id            String    @id @default(uuid())
  name          String
  price         Decimal   @db.Decimal(10, 2)
  printCount    Int       @map("print_count")
  description   String    @db.Text
  isActive      Boolean   @default(true) @map("is_active")
  
  bookings      Booking[]

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  @@map("packages")
}

model Booking {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  packageId     String    @map("package_id")
  bookingDate   DateTime  @db.Date @map("booking_date")
  bookingTime   String    @map("booking_time")
  status        BookingStatus @default(PENDING)
  totalPrice    Decimal   @db.Decimal(10, 2) @map("total_price")

  user          User      @relation(fields: [userId], references: [id])
  package       Package   @relation(fields: [packageId], references: [id])
  payment       Payment?
  queue         Queue?
  gallery       Gallery?

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  @@index([userId])
  @@index([packageId])
  @@index([bookingDate])
  @@map("bookings")
}

model Payment {
  id            String    @id @default(uuid())
  bookingId     String    @unique @map("booking_id")
  method        PaymentMethod
  proofUrl      String?   @map("proof_url")
  status        PaymentStatus @default(PENDING)
  amount        Decimal   @db.Decimal(10, 2)

  booking       Booking   @relation(fields: [bookingId], references: [id])

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  @@map("payments")
}

model Queue {
  id            String    @id @default(uuid())
  bookingId     String    @unique @map("booking_id")
  status        QueueStatus @default(WAITING)
  checkInTime   DateTime  @default(now()) @map("check_in_time")

  booking       Booking   @relation(fields: [bookingId], references: [id])

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  @@map("queues")
}

model Gallery {
  id            String    @id @default(uuid())
  bookingId     String    @unique @map("booking_id")
  folderPath    String    @map("folder_path")
  isWatermarked Boolean   @default(true) @map("is_watermarked")

  booking       Booking   @relation(fields: [bookingId], references: [id])
  images        GalleryImage[]

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  @@map("galleries")
}

model GalleryImage {
  id            String    @id @default(uuid())
  galleryId     String    @map("gallery_id")
  filePath      String    @map("file_path")
  fileName      String    @map("file_name")
  uploadedBy    String    @map("uploaded_by") // e.g. Fotografer ID

  gallery       Gallery   @relation(fields: [galleryId], references: [id])
  printSelection PrintSelection?

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  @@index([galleryId])
  @@map("gallery_images")
}

model PrintSelection {
  id              String    @id @default(uuid())
  galleryImageId  String    @unique @map("gallery_image_id")
  isPrinted       Boolean   @default(false) @map("is_printed")

  galleryImage    GalleryImage @relation(fields: [galleryImageId], references: [id])

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  @@map("print_selections")
}

model SystemSetting {
  id          String    @id @default(uuid())
  key         String    @unique
  value       String    @db.Text
  description String?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("system_settings")
}

model ActivityLog {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  action      String
  description String    @db.Text

  user        User?     @relation(fields: [userId], references: [id])

  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("activity_logs")
}
